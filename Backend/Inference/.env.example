QAIHUB_API_TOKEN=
QAIHUB_DEVICE=Samsung Galaxy S25 (Family)
QAIHUB_TARGET_RUNTIME=tflite
MODEL_PATH=
CLASSIFIER_MODEL_PATH=models/classifier.onnx
MODEL_HF_DIR=
REQUIRE_EXTERNAL_MODEL=false
REQUIRE_NPU=false
MODEL_LABELS=benign_keratosis-like_lesions,basal_cell_carcinoma,actinic_keratoses,vascular_lesions,melanocytic_Nevi,melanoma,dermatofibroma
MODEL_INPUT_SIZE=224
ORT_EXECUTION_PROVIDERS=QNNExecutionProvider,CPUExecutionProvider
ORT_ENABLE_CPU_FALLBACK=true
QNN_BACKEND_PATH=
QNN_HTP_PERFORMANCE_MODE=
QNN_PROFILING_LEVEL=
SEGMENTER_MODEL_PATH=models/Ahmed-Selem__Shifaa-Skin-Cancer-UNet-Segmentation/segmenter.onnx
SEGMENTER_INPUT_SIZE=128
SEGMENTER_THRESHOLD=0.45
SEGMENTER_MIN_AREA_RATIO=0.01
SEGMENTER_MAX_AREA_RATIO=0.85
FUSION_MARGIN=0.05
FUSION_MIN_CROP_CONFIDENCE=0.55
FUSION_MIN_BOX_SCORE=0.08
LOCALIZATION_MODE=classifier_first
SALIENCY_PERCENTILE=93
SALIENCY_MIN_AREA_RATIO=0.01
SALIENCY_MAX_AREA_RATIO=0.85
